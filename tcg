<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TCG Nebula - 顶级卡牌管理系统</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入图标库 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Noto+Sans+SC:wght@300;400;700&display=swap');
        
        :root {
            --primary-gold: #d4af37;
            --nebula-dark: #0f172a;
            --nebula-glass: rgba(30, 41, 59, 0.7);
        }

        body { 
            font-family: 'Noto Sans SC', sans-serif; 
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #020617 100%);
            background-attachment: fixed;
            color: #e2e8f0;
        }

        .nebula-card {
            background: var(--nebula-glass);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 1.25rem;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        .gold-border {
            border: 1px solid var(--primary-gold);
        }

        .category-pill {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.05);
        }

        .category-pill.active {
            background: var(--primary-gold);
            color: #000;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
            border-color: var(--primary-gold);
        }

        .img-container {
            transition: transform 0.3s ease;
        }
        .img-container:hover {
            transform: scale(1.05);
        }

        .trend-up { color: #4ade80; text-shadow: 0 0 8px rgba(74, 222, 128, 0.3); }
        .trend-down { color: #f87171; text-shadow: 0 0 8px rgba(248, 113, 113, 0.3); }

        .price-link-group {
            position: absolute;
            background: #1e293b;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
            display: none;
            z-index: 100;
        }
        .price-trigger-container:hover .price-link-group {
            display: flex;
            flex-direction: column;
        }

        /* 滚动条美化 */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary-gold); }

        input, select, textarea {
            background: rgba(15, 23, 42, 0.6) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: white !important;
        }
        input:focus { border-color: var(--primary-gold) !important; ring: 1px var(--primary-gold); }
        
        .stat-label { font-family: 'Orbitron', sans-serif; letter-spacing: 1px; }
    </style>
</head>
<body class="min-h-screen pb-20">

    <div class="max-w-7xl mx-auto px-4 py-10">
        <!-- Header -->
        <header class="flex flex-col lg:flex-row lg:items-end justify-between mb-10 gap-6">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <i data-lucide="layers" class="text-[#d4af37] w-8 h-8"></i>
                    <h1 class="text-4xl font-bold tracking-tighter italic" style="font-family: 'Orbitron', sans-serif;">RubinCai & TCG NEBULA</h1>
                </div>
                <p class="text-indigo-300/70 text-sm font-light">万物皆可收藏 · 价值由心定义</p>
            </div>
            <div class="flex gap-4">
                <button onclick="exportData()" class="flex items-center gap-2 px-5 py-2.5 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 transition-all text-sm">
                    <i data-lucide="download" class="w-4 h-4 text-indigo-400"></i> 导出档案
                </button>
                <button onclick="toggleModal(true)" class="flex items-center gap-2 px-6 py-2.5 rounded-xl bg-[#d4af37] hover:bg-[#b8962d] text-black font-bold transition-all shadow-[0_0_20px_rgba(212,175,55,0.2)]">
                    <i data-lucide="plus" class="w-5 h-5"></i> 录入新卡
                </button>
            </div>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
            <div class="nebula-card p-6 border-l-4 border-[#d4af37]">
                <p class="stat-label text-[10px] text-indigo-300/50 uppercase mb-1">Total Assets</p>
                <div class="flex items-baseline gap-2">
                    <span id="stat-total-cards" class="text-3xl font-bold">0</span>
                    <span class="text-xs text-indigo-300/40">件</span>
                </div>
            </div>
            <div class="nebula-card p-6 border-l-4 border-indigo-500">
                <p class="stat-label text-[10px] text-indigo-300/50 uppercase mb-1">Market Value</p>
                <div class="flex items-baseline gap-1">
                    <span class="text-sm font-bold text-indigo-400">¥</span>
                    <span id="stat-total-value" class="text-2xl font-bold">0.00</span>
                </div>
            </div>
            <div class="nebula-card p-6 border-l-4 border-emerald-500">
                <p class="stat-label text-[10px] text-indigo-300/50 uppercase mb-1">Grade Score</p>
                <div class="flex items-center gap-2">
                    <span id="stat-avg-score" class="text-3xl font-bold">0.0</span>
                    <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i>
                </div>
            </div>
            <div class="nebula-card p-6 border-l-4 border-pink-500">
                <p class="stat-label text-[10px] text-indigo-300/50 uppercase mb-1">Trading Hubs</p>
                <div class="flex gap-3 mt-1">
                    <span class="text-xs bg-white/5 px-2 py-1 rounded">eBay</span>
                    <span class="text-xs bg-white/5 px-2 py-1 rounded">卡淘</span>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <div class="flex flex-col md:flex-row gap-4 mb-8">
            <div class="flex-1 relative group">
                <i data-lucide="search" class="absolute left-4 top-3 w-4 h-4 text-indigo-300/40 group-focus-within:text-[#d4af37] transition-colors"></i>
                <input type="text" id="search-input" placeholder="搜索卡片名、系列或渠道..." class="w-full pl-12 pr-4 py-3 nebula-card focus:outline-none transition-all">
            </div>
            <div class="flex flex-wrap gap-2 overflow-x-auto pb-2">
                <div onclick="filterByCategory('All')" id="cat-All" class="category-pill active px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">全部</div>
                <div onclick="filterByCategory('宝可梦')" id="cat-宝可梦" class="category-pill px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">宝可梦</div>
                <div onclick="filterByCategory('球星卡')" id="cat-球星卡" class="category-pill px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">球星卡</div>
                <div onclick="filterByCategory('乐高')" id="cat-乐高" class="category-pill px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">乐高</div>
                <div onclick="filterByCategory('万智牌')" id="cat-万智牌" class="category-pill px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">万智牌</div>
                <div onclick="filterByCategory('其他')" id="cat-其他" class="category-pill px-5 py-2.5 rounded-xl text-sm whitespace-nowrap">其他</div>
            </div>
        </div>

        <!-- Main Collection -->
        <div class="nebula-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/5 text-[10px] stat-label text-indigo-300/40 uppercase tracking-widest border-b border-white/5">
                            <th class="px-8 py-5">预览</th>
                            <th class="px-6 py-5">卡片详细档案</th>
                            <th class="px-6 py-5 text-center">来源</th>
                            <th class="px-6 py-5 text-center">趋势</th>
                            <th class="px-6 py-5 text-center">品相</th>
                            <th class="px-6 py-5 text-right">购入价</th>
                            <th class="px-8 py-5 text-right">管理</th>
                        </tr>
                    </thead>
                    <tbody id="cards-table-body" class="divide-y divide-white/5"></tbody>
                </table>
            </div>
            <div id="empty-state" class="hidden py-32 text-center text-indigo-300/20 italic">
                <i data-lucide="ghost" class="w-12 h-12 mx-auto mb-4 opacity-10"></i>
                <p>星云档案库尚无数据...</p>
            </div>
        </div>
    </div>

    <!-- Modal System -->
    <div id="card-modal" class="fixed inset-0 bg-black/80 hidden flex items-center justify-center z-50 p-4 backdrop-blur-md">
        <div class="nebula-card w-full max-w-5xl flex flex-col md:flex-row overflow-hidden max-h-[90vh]">
            <!-- Modal Side Info -->
            <div class="md:w-1/3 bg-black/30 p-8 border-r border-white/5 flex flex-col">
                <div class="mb-6">
                    <h3 class="stat-label text-[#d4af37] text-sm mb-1 uppercase">Visual Asset</h3>
                    <p class="text-xs text-indigo-300/40">上传高清实拍有助于价值追踪</p>
                </div>
                
                <div onclick="document.getElementById('image-input').click()" class="relative aspect-[3/4] nebula-card bg-white/5 flex flex-col items-center justify-center cursor-pointer group hover:border-[#d4af37]/50 transition-all overflow-hidden">
                    <input type="file" id="image-input" accept="image/*" class="hidden" onchange="handleImageUpload(event)">
                    <div id="image-placeholder" class="text-center p-6 transition-transform group-hover:scale-110">
                        <i data-lucide="camera" class="w-10 h-10 mx-auto mb-3 text-indigo-300/20 group-hover:text-[#d4af37]/60"></i>
                        <p class="text-[10px] text-indigo-300/30">DROP PHOTO HERE</p>
                    </div>
                    <img id="image-display" class="hidden w-full h-full object-cover">
                </div>

                <div id="modal-analysis" class="mt-8 hidden p-5 rounded-xl bg-indigo-500/10 border border-indigo-500/20">
                    <div class="flex items-center gap-2 mb-2">
                        <i data-lucide="brain-circuit" class="w-4 h-4 text-indigo-400"></i>
                        <span class="text-xs font-bold text-indigo-300 uppercase">AI Insights</span>
                    </div>
                    <p id="analysis-future" class="text-xs text-indigo-100/60 leading-relaxed"></p>
                </div>
            </div>

            <!-- Form Content -->
            <div class="flex-1 p-8 overflow-y-auto">
                <div class="flex justify-between items-start mb-8">
                    <div>
                        <h2 id="modal-title" class="text-3xl font-bold tracking-tight">录入新卡档案</h2>
                        <p class="text-indigo-300/40 text-xs mt-1 uppercase stat-label">Archiving new collectible card</p>
                    </div>
                    <button onclick="toggleModal(false)" class="p-2 hover:bg-white/10 rounded-full transition-all">
                        <i data-lucide="x" class="w-6 h-6 text-white/50"></i>
                    </button>
                </div>

                <form id="card-form" class="space-y-6">
                    <input type="hidden" id="edit-id">
                    <input type="hidden" id="card-image-data">
                    
                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Category 品类</label>
                            <select id="card-category" required class="w-full px-4 py-3 rounded-xl focus:outline-none">
                                <option value="宝可梦">宝可梦</option>
                                <option value="球星卡">球星卡</option>
                                <option value="乐高">乐高</option>
                                <option value="万智牌">万智牌</option>
                                <option value="其他">其他</option>
                            </select>
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Source 来源渠道</label>
                            <select id="card-channel" onchange="handleChannelChange(this)" class="w-full px-4 py-3 rounded-xl focus:outline-none">
                                <option value="闲鱼">闲鱼</option>
                                <option value="集换社">集换社</option>
                                <option value="卡淘">卡淘</option>
                                <option value="eBay">eBay</option>
                                <option value="卡乐">卡乐</option>
                                <option value="煤炉">煤炉</option>
                                <option value="实体店">实体店</option>
                                <option value="CUSTOM">+ 自定义来源...</option>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Collectible Name 藏品全称</label>
                        <input type="text" id="card-name" required placeholder="例如: PSA 10 莉莉艾 421/SM-P" class="w-full px-4 py-3 rounded-xl focus:outline-none">
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Set/Series 系列</label>
                            <input type="text" id="card-set" placeholder="例如: 太阳与月亮 特典" class="w-full px-4 py-3 rounded-xl focus:outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Condition 评分/成色</label>
                            <input type="text" id="card-rarity" placeholder="例如: PSA 10 / BGS 9.5" class="w-full px-4 py-3 rounded-xl focus:outline-none">
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Quantity 数量</label>
                            <input type="number" id="card-count" min="1" required class="w-full px-4 py-3 rounded-xl focus:outline-none">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Purchase Price 购入价</label>
                            <input type="number" id="card-price" step="0.01" class="w-full px-4 py-3 rounded-xl focus:outline-none">
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label class="block text-[10px] stat-label text-indigo-300/50 uppercase">Special Notes 备注信息</label>
                        <textarea id="card-notes" rows="2" class="w-full px-4 py-3 rounded-xl focus:outline-none"></textarea>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <button type="button" onclick="toggleModal(false)" class="flex-1 py-3 border border-white/5 rounded-xl hover:bg-white/5 transition-all text-sm">放弃修改</button>
                        <button type="submit" class="flex-1 py-3 bg-[#d4af37] text-black font-black rounded-xl hover:bg-[#b8962d] transition-all shadow-[0_10px_20px_rgba(212,175,55,0.1)]">永久存档</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let cards = JSON.parse(localStorage.getItem('tcg_nebula_v1')) || [];
        let currentFilterCategory = 'All';

        const tableBody = document.getElementById('cards-table-body');
        const emptyState = document.getElementById('empty-state');
        const cardForm = document.getElementById('card-form');
        const modal = document.getElementById('card-modal');
        const searchInput = document.getElementById('search-input');
        const imageDataInput = document.getElementById('card-image-data');
        const imageDisplay = document.getElementById('image-display');
        const imagePlaceholder = document.getElementById('image-placeholder');

        // 初始化 Lucide 图标
        function initIcons() { lucide.createIcons(); }

        function getCardAnalysis(card) {
            const seed = parseInt(card.id.slice(-6), 16) || 8888;
            const trendValue = ((seed % 30) - 10);
            const trendLabel = trendValue >= 0 ? `+${trendValue}%` : `${trendValue}%`;
            const trendClass = trendValue >= 0 ? 'trend-up' : 'trend-down';
            const predictions = ["绝版预期: 极高", "主流热度: 稳健", "市场抛售: 风险", "核心藏品: 保值", "玩家心头好: 溢价"];
            const futurePrediction = predictions[seed % predictions.length];
            let score = ((seed % 3) + 7).toFixed(1);
            return { trendLabel, trendClass, futurePrediction, score };
        }

        function toggleModal(show) {
            if (!show) {
                cardForm.reset();
                document.getElementById('edit-id').value = '';
                document.getElementById('modal-title').textContent = '录入新卡档案';
                imageDisplay.src = '';
                imageDisplay.classList.add('hidden');
                imagePlaceholder.classList.remove('hidden');
                imageDataInput.value = '';
                document.getElementById('modal-analysis').classList.add('hidden');
            }
            modal.classList.toggle('hidden', !show);
        }

        function handleChannelChange(select) {
            if (select.value === 'CUSTOM') {
                const custom = prompt('请输入新来源：');
                if (custom) {
                    const newOpt = new Option(custom, custom);
                    select.add(newOpt, select.options[select.options.length - 1]);
                    select.value = custom;
                } else select.selectedIndex = 0;
            }
        }

        async function handleImageUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    const maxSide = 500;
                    let w = img.width, h = img.height;
                    if (w > h) { if (w > maxSide) { h *= maxSide/w; w = maxSide; } }
                    else { if (h > maxSide) { w *= maxSide/h; h = maxSide; } }
                    canvas.width = w; canvas.height = h;
                    ctx.drawImage(img, 0, 0, w, h);
                    imageDataInput.value = canvas.toDataURL('image/jpeg', 0.7);
                    imageDisplay.src = imageDataInput.value;
                    imageDisplay.classList.remove('hidden');
                    imagePlaceholder.classList.add('hidden');
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }

        function filterByCategory(category) {
            currentFilterCategory = category;
            document.querySelectorAll('.category-pill').forEach(el => el.classList.remove('active'));
            document.getElementById(`cat-${category}`).classList.add('active');
            updateUI();
        }

        function updateUI() {
            const term = searchInput.value.toLowerCase();
            const filtered = cards.filter(c => {
                const matchText = [c.name, c.channel, c.notes].some(f => (f || '').toLowerCase().includes(term));
                const matchCat = currentFilterCategory === 'All' || c.category === currentFilterCategory;
                return matchText && matchCat;
            });

            // Summary Stats Calculation
            const totalCount = cards.reduce((s, c) => s + parseInt(c.count), 0);
            const totalVal = cards.reduce((s, c) => s + (c.count * (c.price || 0)), 0);
            const avgScore = cards.length > 0 ? (cards.reduce((s, c) => s + parseFloat(getCardAnalysis(c).score), 0) / cards.length).toFixed(1) : "0.0";
            
            document.getElementById('stat-total-cards').textContent = totalCount;
            document.getElementById('stat-total-value').textContent = totalVal.toLocaleString(undefined, {minimumFractionDigits: 2});
            document.getElementById('stat-avg-score').textContent = avgScore;

            tableBody.innerHTML = '';
            if (filtered.length === 0) {
                emptyState.classList.remove('hidden');
            } else {
                emptyState.classList.add('hidden');
                filtered.forEach(card => {
                    const analysis = getCardAnalysis(card);
                    const searchTitle = encodeURIComponent(card.name + (card.set ? ' ' + card.set : ''));
                    const row = document.createElement('tr');
                    row.className = 'hover:bg-white/[0.02] transition-colors group';
                    row.innerHTML = `
                        <td class="px-8 py-5">
                            <div class="img-container w-14 h-20 nebula-card overflow-hidden shadow-2xl gold-border/20">
                                ${card.image ? `<img src="${card.image}" class="w-full h-full object-cover">` : `<div class="h-full flex flex-col items-center justify-center text-[8px] text-white/10"><i data-lucide="image" class="w-4 h-4 mb-1"></i>无图</div>`}
                            </div>
                        </td>
                        <td class="px-6 py-5">
                            <div class="text-[9px] stat-label text-indigo-400 font-bold uppercase tracking-widest mb-1">${card.category}</div>
                            <div class="font-bold text-gray-100 leading-tight group-hover:text-[#d4af37] transition-colors">${card.name}</div>
                            <div class="text-[10px] text-white/20 mt-1">${card.set || '未知系列'}</div>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="px-2.5 py-1 rounded-lg bg-indigo-500/10 text-indigo-300 text-[10px] font-bold border border-indigo-500/20">${card.channel}</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <div class="text-xs font-bold ${analysis.trendClass}">${analysis.trendLabel}</div>
                            <div class="text-[10px] text-white/20">${analysis.futurePrediction}</div>
                        </td>
                        <td class="px-6 py-5 text-center">
                            <span class="px-3 py-1 rounded-full ${parseFloat(analysis.score) >= 8.5 ? 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30' : 'bg-indigo-500/20 text-indigo-300 border-indigo-500/30'} text-[10px] font-bold border">${analysis.score}</span>
                        </td>
                        <td class="px-6 py-5 text-right font-mono text-sm text-indigo-200">¥${parseFloat(card.price || 0).toFixed(2)}</td>
                        <td class="px-8 py-5 text-right">
                            <div class="price-trigger-container relative inline-block text-left">
                                <button class="p-2 hover:bg-white/10 rounded-lg transition-all">
                                    <i data-lucide="more-horizontal" class="w-5 h-5 text-white/30"></i>
                                </button>
                                <div class="price-link-group right-0 mt-1 w-40">
                                    <a href="https://www.cardhobby.com.cn/market/search?keyword=${searchTitle}" target="_blank" class="px-4 py-2.5 text-xs text-white/70 hover:bg-white/5 hover:text-[#d4af37] transition-all flex items-center">
                                        <i data-lucide="line-chart" class="w-3.5 h-3.5 mr-3"></i> 卡淘查价
                                    </a>
                                    <a href="https://www.ebay.com/sch/i.html?_nkw=${searchTitle}" target="_blank" class="px-4 py-2.5 text-xs text-white/70 hover:bg-white/5 hover:text-[#d4af37] transition-all flex items-center border-t border-white/5">
                                        <i data-lucide="globe" class="w-3.5 h-3.5 mr-3"></i> eBay查价
                                    </a>
                                    <button onclick="editCard('${card.id}')" class="w-full text-left px-4 py-2.5 text-xs text-indigo-400 hover:bg-white/5 transition-all flex items-center border-t border-white/5">
                                        <i data-lucide="edit-3" class="w-3.5 h-3.5 mr-3"></i> 档案修订
                                    </button>
                                    <button onclick="deleteCard('${card.id}')" class="w-full text-left px-4 py-2.5 text-xs text-red-400 hover:bg-red-500/10 transition-all flex items-center border-t border-white/5">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5 mr-3"></i> 彻底删除
                                    </button>
                                </div>
                            </div>
                        </td>
                    `;
                    tableBody.appendChild(row);
                });
                initIcons();
            }
        }

        function editCard(id) {
            const c = cards.find(x => x.id === id);
            if(!c) return;
            document.getElementById('edit-id').value = c.id;
            document.getElementById('card-category').value = c.category;
            document.getElementById('card-name').value = c.name;
            document.getElementById('card-set').value = c.set;
            document.getElementById('card-rarity').value = c.rarity;
            document.getElementById('card-count').value = c.count;
            document.getElementById('card-price').value = c.price;
            document.getElementById('card-notes').value = c.notes;
            
            const chanSelect = document.getElementById('card-channel');
            if (!Array.from(chanSelect.options).some(o => o.value === c.channel)) {
                chanSelect.add(new Option(c.channel, c.channel), chanSelect.options[chanSelect.options.length-1]);
            }
            chanSelect.value = c.channel;

            if(c.image) {
                imageDataInput.value = c.image;
                imageDisplay.src = c.image;
                imageDisplay.classList.remove('hidden');
                imagePlaceholder.classList.add('hidden');
            }
            document.getElementById('modal-analysis').classList.remove('hidden');
            const analysis = getCardAnalysis(c);
            document.getElementById('analysis-future').innerHTML = `<b>档案评分:</b> ${analysis.score}/10<br><b>收藏建议:</b> ${analysis.futurePrediction}`;
            document.getElementById('modal-title').textContent = '档案修订';
            toggleModal(true);
        }

        function saveStorage() {
            localStorage.setItem('tcg_nebula_v1', JSON.stringify(cards));
            updateUI();
        }

        cardForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const id = document.getElementById('edit-id').value;
            const data = {
                id: id || Date.now().toString(),
                category: document.getElementById('card-category').value,
                channel: document.getElementById('card-channel').value,
                name: document.getElementById('card-name').value,
                set: document.getElementById('card-set').value,
                rarity: document.getElementById('card-rarity').value,
                count: document.getElementById('card-count').value,
                price: document.getElementById('card-price').value,
                notes: document.getElementById('card-notes').value,
                image: imageDataInput.value
            };
            if(id) cards = cards.map(x => x.id === id ? data : x);
            else cards.unshift(data);
            saveStorage();
            toggleModal(false);
        });

        function deleteCard(id) {
            if(confirm('确定要销毁该收藏档案吗？此操作不可撤销。')) {
                cards = cards.filter(c => c.id !== id);
                saveStorage();
            }
        }

        function exportData() {
            const headers = ['品类', '名称', '渠道', '数量', '单价'];
            const rows = cards.map(c => [c.category, c.name, c.channel, c.count, c.price]);
            const csv = "\uFEFF" + headers.join(",") + "\n" + rows.map(r => r.join(",")).join("\n");
            const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `NEBULA_DECK_EXPORT_${new Date().toISOString().slice(0,10)}.csv`;
            a.click();
        }

        searchInput.addEventListener('input', updateUI);
        window.onload = () => {
            updateUI();
            initIcons();
        };
    </script>
</body>
</html>
